@model IEnumerable<Lab_rab_3._Shakurov_Almir_БПИ_23_02.Models.Vegetable>

<h2>Отсортированные фрукты</h2>

<table class="table">
    <thead>
        <tr>
            <th>Название</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Name</td>
            </tr>
        }
    </tbody>
</table>
